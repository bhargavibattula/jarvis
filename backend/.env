# FastAPI Settings
PROJECT_NAME="Jarvis AI"
DEBUG=true
API_V1_STR="/api/v1"

# Security
SECRET_KEY="your-super-secret-key-for-jwt-and-sessions"
ALLOWED_HOSTS=["http://localhost:5173", "http://localhost:3000"]

# LLM Providers
ANTHROPIC_API_KEY="your-anthropic-key"
OPENAI_API_KEY="your-openai-key"

# External Search
TAVILY_API_KEY="your-tavily-key"

# Weather & News
OPENWEATHERMAP_API_KEY="your-owm-key"
NEWS_API_KEY="your-newsapi-key"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/jarvis"
REDIS_URL="redis://localhost:6379/0"

# Vector DB
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# Code Sandbox
E2B_API_KEY="your-e2b-key"

# Google AI
GOOGLE_APPLICATION_CREDENTIALS="path/to/credentials.json"
